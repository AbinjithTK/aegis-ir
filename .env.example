# --- Google Gemini (Required) ---
# API key path (simplest): get from https://aistudio.google.com/
GOOGLE_API_KEY=

# Model override (optional — defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# --- Phoenix Cloud (Required for observability + self-introspection) ---
# Create a free account: https://app.phoenix.arize.com
# API key format: px_live_...
PHOENIX_API_KEY=
# REQUIRED: copy Hostname from Phoenix → Settings (includes /s/<space>)
# Example: https://app.phoenix.arize.com/s/my-team-space
PHOENIX_COLLECTOR_ENDPOINT=
# Project name in Phoenix
PHOENIX_PROJECT_NAME=sift-defender

# --- Evidence Configuration ---
SIFT_EVIDENCE_MOUNT=/mnt/evidence
SIFT_CASE_DIR=/cases/active

# --- Web Interface ---
SIFT_DEFENDER_PORT=8080
SIFT_DEFENDER_HOST=0.0.0.0
