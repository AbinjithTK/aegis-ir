{
  "mcpServers": {
    "phoenix": {
      "command": "npx",
      "args": ["@arizeai/phoenix-mcp@latest"],
      "env": {
        "PHOENIX_API_KEY": "${PHOENIX_API_KEY}",
        "PHOENIX_COLLECTOR_ENDPOINT": "${PHOENIX_COLLECTOR_ENDPOINT}",
        "PHOENIX_PROJECT_NAME": "sift-defender"
      }
    }
  }
}
